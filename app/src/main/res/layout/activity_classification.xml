<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fault Classification"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSelectCfg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select CFG File"/>

        <Button
            android:id="@+id/btnSelectDat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select DAT File"/>

        <Button
            android:id="@+id/btnClassify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Classify Fault"/>

        <Button
            android:id="@+id/btnOpenMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Station on Map"/>

        <TextView
            android:id="@+id/tvCfgFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CFG: Not Selected"/>

        <TextView
            android:id="@+id/tvDatFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DAT: Not Selected"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result"
            android:textSize="16sp"/>
        <Button
            android:id="@+id/btnAiAssistant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Fault Assistant" />

    </LinearLayout>

</ScrollView>